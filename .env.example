# ============================================
# Meteora DLMM LP Bot — Environment Variables
# ============================================

# ── REQUIRED ──

# Solana wallet private key (base58 encoded)
# WARNING: Never commit this to git. Never share this.
PRIVATE_KEY=your_base58_private_key_here

# RPC URL — Use Helius or QuickNode (NOT public RPC)
# Example: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Example Devnet: https://devnet.helius-rpc.com/?api-key=YOUR_KEY
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Helius API Key (for RPC + enhanced APIs)
HELIUS_API_KEY=your_helius_api_key

# ── CAPITAL CONFIG ──

# Total capital in USD ($100-$300 range supported)
TOTAL_CAPITAL_USD=200

# Gas reserve percentage (default 10%)
GAS_RESERVE_PCT=0.10

# ── THRESHOLDS ──

# Minimum APR% to enter a position (default 250)
MIN_APR_PCT=250

# APR% below which to exit (default 50)
EXIT_APR_PCT=50

# APR% warning zone (default 100)
WARNING_APR_PCT=100

# Volume/TVL ratio thresholds
VOLUME_TVL_PRIMARY=1.0
VOLUME_TVL_FALLBACK=0.7

# ── IL THRESHOLDS ──

# IL% to trigger rebalance for TIER1 (default -8)
IL_TIER1_THRESHOLD=-8

# IL% to trigger rebalance for TIER2 (default -6)
IL_TIER2_THRESHOLD=-6

# IL% hard stop loss (default -15)
IL_STOP_LOSS=-15

# Price crash% to trigger emergency close (default -20)
PRICE_CRASH_PCT=-20

# ── MONITORING INTERVALS ──

# Monitor cycle interval in ms (default 5 min = 300000)
MONITOR_INTERVAL_MS=300000

# Volatile regime monitor interval in ms (default 3 min = 180000)
VOLATILE_MONITOR_MS=180000

# Scan cycle interval in ms (default 30 min = 1800000)
SCAN_INTERVAL_MS=1800000

# Transaction stuck timeout in ms (default 60 sec = 60000)
STUCK_TX_TIMEOUT_MS=60000

# Max wait for out-of-range before action in ms (default 15 min = 900000)
OOR_MAX_WAIT_MS=900000

# ── FEE SETTINGS ──

# Minimum fee claim amount in USD (default 0.50)
MIN_CLAIM_USD=0.50

# Auto-compound threshold in USD (default 5)
COMPOUND_THRESHOLD_USD=5

# Fee reserve warning threshold in USD (default 20)
FEE_RESERVE_WARN_USD=20

# Priority fee level for volatile regime (high/medium/low)
PRIORITY_FEE_VOLATILE=high

# Priority fee level for normal regime (high/medium/low)
PRIORITY_FEE_NORMAL=medium

# ── CIRCUIT BREAKER ──

# Max consecutive losses before circuit breaker triggers (default 3)
MAX_CONSECUTIVE_LOSSES=3

# ── API TIMEOUTS ──

# General API timeout in ms (default 10000)
API_TIMEOUT_MS=10000

# Transaction confirmation timeout in ms (default 60000)
CONFIRM_TIMEOUT_MS=60000

# ── GAS SETTINGS ──

# Minimum SOL balance required (default 0.15)
MIN_GAS_SOL=0.15

# Minimum wallet balance in USD (default 30)
MIN_WALLET_BALANCE_USD=30

# ── REBALANCE SETTINGS ──

# Bins drift threshold to trigger rebalance (default 8)
REBALANCE_DRIFT_THRESHOLD=8

# Fee multiplier for cost-benefit analysis (default 2)
REBALANCE_FEE_MULTIPLIER=2

# Volume drop% to trigger rebalance (default 60)
VOLUME_DROP_PCT=60

# ── BIN STRATEGY ──

# Stable regime
STABLE_BINS_MIN=15
STABLE_BINS_MAX=20
STABLE_BPS_MIN=1
STABLE_BPS_MAX=5

# Ranging regime
RANGING_BINS_MIN=20
RANGING_BINS_MAX=30
RANGING_BPS_MIN=10
RANGING_BPS_MAX=25

# Volatile regime
VOLATILE_BINS_MIN=40
VOLATILE_BINS_MAX=50
VOLATILE_BPS_MIN=25
VOLATILE_BPS_MAX=50

# TIER2 range increase% (default 20)
TIER2_RANGE_PCT=20

# ── LOGGING ──

# Log level: debug | info | warn | error
LOG_LEVEL=info

# ── DEVELOPMENT ──

# Set to "true" to use devnet
DEVNET=false
